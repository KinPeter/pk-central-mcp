{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "pk-central": {
      "type": "local",
      "command": [
        "node",
        "/home/opencode/pk-central-mcp/dist/index.js"
      ],
      "environment": {
        "API_BASE_URL": "{env:PK_CENTRAL_BASE_URL}",
        "API_KEY": "{env:PK_CENTRAL_API_KEY}"
      },
      "enabled": true
    }
  }
}